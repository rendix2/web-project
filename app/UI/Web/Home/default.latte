{block content}
<div class="container py-5">
    <!-- Hero Header -->
    <div id="banner" class="text-white p-5 mb-5 rounded-4 shadow position-relative overflow-hidden">
        <div class="row align-items-center position-relative" style="z-index: 2;">
            <div class="col-md-8">
                <h1 n:block=title class="display-4 fw-bold mb-0">Congratulations!</h1>
                <p class="lead opacity-75 mt-2">
                    You have successfully created your <a href="https://nette.org" target="_blank" class="text-white border-bottom border-white border-opacity-50 text-decoration-none">Nette</a> Web project.
                </p>
                <div class="d-flex gap-3 mt-4 flex-wrap">
                    <a href="https://doc.nette.org/quickstart" target="_blank" class="btn btn-sm btn-light rounded-pill px-3">Quick Start</a>
                    <a href="https://doc.nette.org" target="_blank" class="btn btn-sm btn-outline-light rounded-pill px-3">Documentation</a>
                    <a href="https://forum.nette.org" target="_blank" class="btn btn-sm btn-outline-light rounded-pill px-3">Forum</a>
                    <a href="https://blog.nette.org" target="_blank" class="btn btn-sm btn-outline-light rounded-pill px-3">Blog</a>
                </div>
            </div>
            <div class="col-md-4 text-end d-none d-md-block text-center">
                <img src="data:image/png;base64," alt="Nette Bot" class="img-fluid floating-animation" style="max-height: 150px;">
            </div>
        </div>
        <div class="nette-logo-bg"></div>
    </div>

    <div class="row g-4 text-start">
        <!-- Column 1: Core & System -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h3 class="h6 fw-bold text-primary text-uppercase"><i class="fas fa-microchip me-2"></i>Backend Core</h3>
                </div>
                <div class="card-body px-4 pt-0">
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-3">
                            <a href="https://nette.org" target="_blank" class="text-dark fw-bold text-decoration-none">Nette Framework</a><br>
                            <span class="text-muted">The core of your web application.</span>
                        </li>
                        <li class="mb-3">
                            <a href="https://contributte.org/packages/contributte/console.html" target="_blank" class="text-dark fw-bold text-decoration-none">Symfony Console</a><br>
                            <span class="text-muted">Powerful CLI tools via Contributte.</span>
                        </li>
                        <li>
                            <a href="https://contributte.org/packages/contributte/menu-control.html" target="_blank" class="text-dark fw-bold text-decoration-none">Menu Control</a><br>
                            <span class="text-muted">Elegant navigation management.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Column 2: Data & Persistence -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h3 class="h6 fw-bold text-success text-uppercase"><i class="fas fa-database me-2"></i>Persistence</h3>
                </div>
                <div class="card-body px-4 pt-0">
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-3">
                            <a href="https://contributte.org/nettrine/" target="_blank" class="text-dark fw-bold text-decoration-none">Nettrine (Doctrine)</a><br>
                            <span class="text-muted">Modern object-relational mapping.</span>
                        </li>
                        <li class="mb-3">
                            <a href="https://contributte.org/packages/contributte/doctrine-migrations.html" target="_blank" class="text-dark fw-bold text-decoration-none">Migrations</a><br>
                            <span class="text-muted">Safe database version control.</span>
                        </li>
                        <li>
                            <a href="https://contributte.org/packages/contributte/doctrine-fixtures.html" target="_blank" class="text-dark fw-bold text-decoration-none">Fixtures</a><br>
                            <span class="text-muted">Seed your database with testing data.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Column 3: Frontend Stack -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm rounded-4 border-top border-primary border-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h3 class="h6 fw-bold text-primary text-uppercase"><i class="fas fa-rocket me-2"></i>Frontend</h3>
                </div>
                <div class="card-body px-4 pt-0">
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-3">
                            <a href="https://getbootstrap.com/docs/5.3/getting-started/introduction/" target="_blank" class="text-dark fw-bold text-decoration-none">Bootstrap 5.3</a><br>
                            <span class="text-muted">Responsive and modern UI components.</span>
                        </li>
                        <li class="mb-3">
                            <a href="https://fontawesome.com/" target="_blank" class="text-dark fw-bold text-decoration-none">Font Awesome</a><br>
                            <span class="text-muted">Comprehensive icon library.</span>
                        </li>
                        <li class="mb-3">
                            <a href="https://contributte.org/packages/contributte/webpack.html" target="_blank" class="text-dark fw-bold text-decoration-none">Asset Management</a><br>
                            <span class="text-muted">Webpack or Vite integration.</span>
                        </li>
                        <li>
                            <a href="https://npmjs.com" target="_blank" class="text-dark fw-bold text-decoration-none">NPM Ecosystem</a><br>
                            <span class="text-muted">Package management for JS/CSS.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Column 4: UI Components -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h3 class="h6 fw-bold text-danger text-uppercase"><i class="fas fa-layer-group me-2"></i>Components</h3>
                </div>
                <div class="card-body px-4 pt-0">
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-3">
                            <a href="https://contributte.org/packages/contributte/datagrid/" target="_blank" class="text-dark fw-bold text-decoration-none">Ublaboo Datagrid</a><br>
                            <span class="text-muted">Powerful tables with filtering and AJAX.</span>
                        </li>
                        <li class="mb-3">
                            <a href="https://contributte.org/packages/contributte/forms-bootstrap.html" target="_blank" class="text-dark fw-bold text-decoration-none">Bootstrap Forms</a><br>
                            <span class="text-muted">Automated Nette forms rendering.</span>
                        </li>
                        <li>
                            <a href="https://docker.io" target="_blank" class="text-dark fw-bold text-decoration-none">Docker Support</a><br>
                            <span class="text-muted">Containerized development environment.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Extra Utilities Bar -->
    <div class="mt-4 p-3 bg-white rounded-4 shadow-sm border-0 d-flex flex-wrap align-items-center justify-content-center gap-4">
        <span class="text-muted small fw-bold text-uppercase">Framework Resources:</span>
        <a href="https://contributte.org/" target="_blank" class="text-decoration-none d-flex align-items-center gap-2 small"><i class="fas fa-box text-primary"></i> Contributte Packages</a>
        <a href="https://nette.org" target="_blank" class="text-decoration-none d-flex align-items-center gap-2 small"><i class="fas fa-globe text-primary"></i> Nette.org</a>
    </div>

    <!-- Main Navigation Actions -->
    <div class="mt-5 text-center">
        <div class="d-inline-flex gap-3 bg-dark p-2 rounded-pill shadow">
            <a href="{link :Web:User:Login:default}" class="btn btn-primary px-5 rounded-pill fw-bold">Login</a>
            <a href="{link :Web:User:Registration:default}" class="btn btn-outline-light px-5 rounded-pill fw-bold">Sign up</a>
        </div>
        <!-- Login Credentials Info -->
        <div class="mt-3">
            <p class="text-muted small mb-0">
                Username: <code class="text-primary fw-bold">TestUsername</code> &nbsp;|&nbsp;
                Password: <code class="text-primary fw-bold">Secret</code>
            </p>
        </div>
        <div class="mt-4">
            <p class="text-muted small">
                We hope you enjoy Nette!
            </p>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8fafc;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        color: #1e293b;
    }

    #banner {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        border: none;
    }

    .nette-logo-bg {
        position: absolute;
        right: -50px;
        top: -50px;
        width: 300px;
        height: 300px;
        background: url(https://files.nette.org/images/logo-nette@2.png) no-repeat center;
        background-size: contain;
        opacity: 0.05;
        transform: rotate(-10deg);
    }

    .card {
        transition: all 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.05) !important;
    }

    .card-body a:hover {
        color: #3484d2 !important;
        text-decoration: underline !important;
    }

    .floating-animation {
        animation: float 5s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }

    .btn-primary {
        background-color: #3484d2;
        border-color: #3484d2;
    }
</style>
{/block}