{
  "name": "rendix2/web-project",
  "description": "Nette: Improved Web Project",
  "keywords": [
    "nette",
    "web-project",
    "php"
  ],
  "type": "project",
  "license": [
    "MIT",
    "BSD-3-Clause",
    "GPL-2.0-only",
    "GPL-3.0-only"
  ],
  "homepage": "https://github.com/rendix2/web-project",
  "require": {
    "php": ">= 8.3",
    "ext-ctype": "*",
    "ext-curl": "*",
    "ext-fileinfo": "*",
    "ext-iconv": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "ext-phar": "*",
    "ext-session": "*",
    "ext-simplexml": "*",
    "ext-tokenizer": "*",
    "contributte/console": "^0.11.0",
    "contributte/console-extra": "^0.8.0",
    "contributte/forms-bootstrap": "^0.8",
    "contributte/guzzlette": "^3.4",
    "contributte/mail": "^0.9.0",
    "contributte/mailing": "^0.7.1",
    "contributte/menu-control": "^3.2",
    "contributte/redis": "^0.6.2",
    "contributte/translation": "^2.0.x-dev",
    "donatj/phpuseragentparser": "^1.11",
    "jgxvx/cilician": "^6.1",
    "latte/latte": "^3.1",
    "nette/application": "^3.2",
    "nette/assets": "^1.0",
    "nette/bootstrap": "^3.2",
    "nette/caching": "^3.4",
    "nette/di": "^3.2",
    "nette/forms": "^3.2",
    "nette/http": "^3.3",
    "nette/mail": "^4.1",
    "nette/robot-loader": "^4.1",
    "nette/security": "^3.2",
    "nette/utils": "^4.1",
    "nettrine/dbal": "^v0.10",
    "nettrine/extensions-beberlei": "dev-master",
    "nettrine/fixtures": "^0.9.0",
    "nettrine/migrations": "^v0.10",
    "nettrine/orm": "^v0.10",
    "ramsey/uuid": "^4.9",
    "ramsey/uuid-doctrine": "^2.1",
    "symfony/cache": "^7.4",
    "symfony/var-exporter": "7",
    "tracy/tracy": "^v2.11",
    "ublaboo/datagrid": "^7.2"
  },
  "require-dev": {
    "dg/composer-frontline": "^0.2.0",
    "nette/tester": "^2.5",
    "ninjify/coding-standard": "^0.12.1",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "phpstan/phpstan-doctrine": "^2.0",
    "phpstan/phpstan-nette": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "roave/security-advisories": "dev-latest",
    "symfony/thanks": "^1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app"
    }
  },
  "scripts": {
    "phpstan": "phpstan analyse",
    "tester": "tester tests -s"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "dg/composer-frontline": true,
      "phpstan/extension-installer": true,
      "symfony/thanks": true
    },
    "optimize-autoloader": true,
    "sort-packages": true,
    "lock": true
  }
}
